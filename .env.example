# =========================
# App
# =========================
APP_NAME=RSOD Agent Platform
APP_ENV=development
DEBUG=true

# =========================
# Backend
# =========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# =========================
# PostgreSQL
# =========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rsod_agent
POSTGRES_USER=rsod_admin
POSTGRES_PASSWORD=rsod_password

DATABASE_URL=postgresql://rsod_admin:rsod_password@localhost:5432/rsod_agent

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# =========================
# MinIO
# =========================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=rsod-agent-files
MINIO_SECURE=false

# =========================
# JWT
# =========================
JWT_SECRET_KEY=please_change_this_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# =========================
# LLM
# =========================
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434

# =========================
# YOLO
# =========================
YOLO_MODEL_PATH=models/yolov11n.pt
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
